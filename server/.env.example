# Server-side env vars. Copy this file's content to `.env` and fill
# in real values. The server refuses to start if `SESSION_SECRET`
# is missing or shorter than 16 characters.

# Google OAuth web client id. MUST match the value in `client/.env`
# (VITE_GOOGLE_CLIENT_ID). Used to verify the audience claim on the
# id_token sent by the React client.
GOOGLE_CLIENT_ID=683945826147-grphgfuvdboolv3uka1juq6f0onuskl6.apps.googleusercontent.com

# MongoDB Atlas connection string. Whitelist your IP in Atlas →
# Network Access, then paste the URI here.
MONGODB_URI=

# Long random string (>= 16 chars) used to sign session JWTs.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace-with-a-long-random-string-at-least-16-chars

# Optional. Defaults to 5000.
PORT=5000
